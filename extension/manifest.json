{
  "manifest_version": 3,
  "name": "Okhra — AI Text Detector",
  "version": "1.0.1",
  "description": "Detect AI-generated text. Runs locally — no data leaves your browser.",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/okhra_48px.png"
    }
  },
  "icons": {
    "48": "icons/okhra_48px.png"
  },
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"]
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [{
    "resources": ["model/*", "lib/*", "icons/*"],
    "matches": ["<all_urls>"]
  }],
  "browser_specific_settings": {
    "gecko": {
      "id": "okhra@detector",
      "strict_min_version": "128.0",
      "background": {
        "scripts": ["background.js"]
      }
    }
  }
}
